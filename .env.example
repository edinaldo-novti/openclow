# =============================================================================
# OpenClaw Server - Variáveis de Ambiente
# Copie para .env e preencha os valores
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Gateway OpenClaw
# -----------------------------------------------------------------------------
# Token de autenticação do gateway (gere com: openssl rand -hex 32)
OPENCLAW_GATEWAY_TOKEN=

# Imagem Docker (padrão: ghcr.io/openclaw/openclaw:latest)
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Portas expostas (Coolify gerencia via reverse proxy)
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Bind mode: lan | loopback (use 'lan' para acesso externo via proxy)
OPENCLAW_GATEWAY_BIND=lan

# Estado do OpenClaw: volume nomeado openclaw_data (evita EACCES no Coolify)

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=CHANGE_ME_secure_password
POSTGRES_DB=openclaw

# URL completa (obrigatório se POSTGRES_* diferir do default openclaw/openclaw_secure_password)
# DATABASE_URL=postgresql://openclaw:SUA_SENHA@postgres:5432/openclaw

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# URL completa (opcional - override se usar Redis externo)
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# API Keys - Modelos de IA
# -----------------------------------------------------------------------------
# OpenAI (GPT-4, etc.)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google Gemini - chave em https://aistudio.google.com/apikey
# Modelos: google/gemini-3-pro-preview, google/gemini-2.5-flash, etc.
GEMINI_API_KEY=

# OpenRouter - opcional (acesso a múltiplos modelos)
# OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Modelos Locais (Ollama / LocalAI)
# -----------------------------------------------------------------------------
# URL do Ollama no host (Docker: host.docker.internal)
# Linux: use IP do host ou gateway da rede Docker
OLLAMA_BASE_URL=http://host.docker.internal:11434

# LocalAI (alternativa)
# LOCALAI_BASE_URL=http://host.docker.internal:8080/v1

# -----------------------------------------------------------------------------
# Claude AI Session (opcional - para integração web)
# -----------------------------------------------------------------------------
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=

# -----------------------------------------------------------------------------
# Microsoft Teams (plugin @openclaw/msteams)
# Requer: Azure Bot, App ID, Client Secret, Tenant ID
# Docs: https://docs.openclaw.ai/channels/msteams
# -----------------------------------------------------------------------------
# MSTEAMS_APP_ID=
# MSTEAMS_APP_PASSWORD=
# MSTEAMS_TENANT_ID=
MSTEAMS_WEBHOOK_PORT=3978

# -----------------------------------------------------------------------------
# Mattermost (plugin @openclaw/mattermost)
# Chat self-hosted - use profile: docker compose --profile mattermost up
# Docs: https://docs.openclaw.ai/channels/mattermost
# -----------------------------------------------------------------------------
# MATTERMOST_BASE_URL=http://mattermost:8065
# MATTERMOST_BOT_TOKEN=
MATTERMOST_PORT=8065
MATTERMOST_DB_USER=mmuser
MATTERMOST_DB_PASSWORD=CHANGE_ME_mattermost_db
MATTERMOST_DB_NAME=mattermost
MATTERMOST_SITE_URL=http://localhost:8065

# -----------------------------------------------------------------------------
# Desenvolvimento / Debug
# -----------------------------------------------------------------------------
# OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1
# OPENCLAW_LOG_LEVEL=debug
